{
  "name": "super-bot",
  "version": "1.0.0",
  "description": "Autonomous crypto trading bot powered by Claude AI",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index-parallel.ts",
    "start:short": "tsx src/index-short.ts",
    "start:parallel": "tsx src/index-parallel.ts",
    "dev": "tsx watch src/index.ts",
    "dev:short": "tsx watch src/index-short.ts",
    "dev:parallel": "tsx watch src/index-parallel.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "binance-api-node": "latest",
    "dotenv": "latest",
    "node-cron": "latest",
    "technicalindicators": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/node-cron": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
